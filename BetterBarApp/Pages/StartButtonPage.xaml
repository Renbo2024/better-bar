<Page x:Class="BetterBarApp.Pages.StartButtonPage"
      x:Name="Root"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:BetterBarApp.Controls"
      Title="Start Button">
    <Grid Margin="42,12,42,24" TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <ui:Button Appearance="Transparent" Icon="{ui:SymbolIcon ArrowLeft24}"
                       Content="Back" Click="Back_Click" HorizontalAlignment="Left"/>
            <ui:Button DockPanel.Dock="Right" HorizontalAlignment="Right"
                       Icon="{ui:SymbolIcon Eye24}" Content="Preview menu" Click="Preview_Click"/>
        </DockPanel>
        <TextBlock Grid.Row="1" Text="Start Button" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <ScrollViewer x:Name="PageScroll" Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ── General ── -->
                <TextBlock Text="General" FontWeight="SemiBold" Margin="2,0,0,6"/>
                <ui:CardControl Icon="{ui:SymbolIcon Folder24}" Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Quick Launch folder" FontWeight="SemiBold"/>
                            <TextBlock Text="Shown as the icon list when the menu opens."
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:TextBox x:Name="DirectoryBox" IsReadOnly="True" MinWidth="280" Margin="0,0,8,0"/>
                        <ui:Button Content="Browse…" Click="Browse_Click"/>
                    </StackPanel>
                </ui:CardControl>

                <ui:CardControl Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Button margin (px)" VerticalAlignment="Center"/>
                            <TextBlock Text="Empty space around the Start button on the bar."
                                       FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <controls:NumericBox x:Name="MarginBox" Minimum="0" Maximum="40" Step="1" MinWidth="120" ValueChanged="Basics_Changed"/>
                </ui:CardControl>
                <ui:CardControl Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Icon size (px)" VerticalAlignment="Center"/>
                            <TextBlock Text="Size of each row's icon in the menu's icon list."
                                       FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <controls:NumericBox x:Name="IconSizeBox" Minimum="16" Maximum="64" Step="2" MinWidth="120" ValueChanged="Basics_Changed"/>
                </ui:CardControl>
                <ui:CardControl Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Icon margin (px)" VerticalAlignment="Center"/>
                            <TextBlock Text="Padding around the icon within each menu row."
                                       FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <controls:NumericBox x:Name="IconMarginBox" Minimum="0" Maximum="20" Step="1" MinWidth="120" ValueChanged="Basics_Changed"/>
                </ui:CardControl>
                <ui:CardControl Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Text margin (px)" VerticalAlignment="Center"/>
                            <TextBlock Text="Padding around the label within each menu row."
                                       FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <controls:NumericBox x:Name="TextMarginBox" Minimum="0" Maximum="20" Step="1" MinWidth="120" ValueChanged="Basics_Changed"/>
                </ui:CardControl>
                <ui:CardControl Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Text size (px)" VerticalAlignment="Center"/>
                            <TextBlock Text="Font size of the menu row labels."
                                       FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <controls:NumericBox x:Name="TextSizeBox" Minimum="10" Maximum="24" Step="1" MinWidth="120" ValueChanged="Basics_Changed"/>
                </ui:CardControl>
                <ui:CardControl Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Max text width (px)" VerticalAlignment="Center"/>
                            <TextBlock Text="Width at which long labels are truncated with an ellipsis."
                                       FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <controls:NumericBox x:Name="MaxTextWidthBox" Minimum="80" Maximum="500" Step="10" MinWidth="120" ValueChanged="Basics_Changed"/>
                </ui:CardControl>
                <ui:CardControl Margin="0,0,0,16">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Minimum menu height (px)" VerticalAlignment="Center"/>
                            <TextBlock Text="Keeps room for search results when the icon list is short or empty."
                                       FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <controls:NumericBox x:Name="MinMenuHeightBox" Minimum="120" Maximum="900" Step="20" MinWidth="120" ValueChanged="Basics_Changed"/>
                </ui:CardControl>

                <!-- ── Search ── -->
                <TextBlock Text="Search" FontWeight="SemiBold" Margin="2,0,0,6"/>
                <ui:CardControl Icon="{ui:SymbolIcon Search24}" Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Search in" VerticalAlignment="Center"/>
                            <TextBlock Text="Which built-in sources this button's type-to-find searches."
                                       FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <WrapPanel>
                        <CheckBox x:Name="SearchQuickLaunchBox" Content="Quick Launch" Margin="0,0,16,0" Click="Sources_Changed"/>
                        <CheckBox x:Name="SearchAppsBox"        Content="Apps"        Margin="0,0,16,0" Click="Sources_Changed"/>
                        <CheckBox x:Name="SearchSettingsBox"    Content="Settings"    Margin="0,0,16,0" Click="Sources_Changed"/>
                        <CheckBox x:Name="SearchDocumentsBox"   Content="Documents"   Click="Sources_Changed"/>
                    </WrapPanel>
                </ui:CardControl>
                <ui:CardControl Icon="{ui:SymbolIcon History24}" Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Recency ranking" FontWeight="SemiBold"/>
                            <TextBlock Text="Boost results you open often/recently, per built-in source."
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <WrapPanel>
                        <CheckBox x:Name="RecencyQuickLaunchBox" Content="Quick Launch" Margin="0,0,16,0" Click="Recency_Changed"/>
                        <CheckBox x:Name="RecencyAppsBox"        Content="Apps"        Margin="0,0,16,0" Click="Recency_Changed"/>
                        <CheckBox x:Name="RecencySettingsBox"    Content="Settings"    Margin="0,0,16,0" Click="Recency_Changed"/>
                        <CheckBox x:Name="RecencyDocumentsBox"   Content="Documents"   Click="Recency_Changed"/>
                    </WrapPanel>
                </ui:CardControl>
                <ui:CardControl Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Max results" VerticalAlignment="Center"/>
                            <TextBlock Text="Most search results shown at once."
                                       FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <controls:NumericBox x:Name="SearchMaxBox" Minimum="3" Maximum="30" Step="1" MinWidth="120" ValueChanged="Basics_Changed"/>
                </ui:CardControl>
                <ui:CardControl Margin="0,0,0,16">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Result fade (ms)" FontWeight="SemiBold"/>
                            <TextBlock Text="0 = instant." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <controls:NumericBox x:Name="SearchFadeBox" Minimum="0" Maximum="500" Step="10" MinWidth="120" ValueChanged="Basics_Changed"/>
                </ui:CardControl>

                <!-- ── Search aliases ── -->
                <TextBlock Text="Aliases" FontWeight="SemiBold" Margin="2,0,0,2"/>
                <TextBlock Text="One per line, e.g.  ps = powershell.  Typing an alias also searches its expansion; expansion matches rank above results that merely contain the literal alias."
                           FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" Margin="2,0,0,6"/>
                <ui:TextBox x:Name="AliasesBox"
                            AcceptsReturn="True" TextWrapping="NoWrap"
                            FontFamily="Consolas"
                            MinLines="3" MaxLines="10"
                            VerticalScrollBarVisibility="Auto"
                            PlaceholderText="ps = powershell"
                            TextChanged="Aliases_Changed" Margin="0,0,0,16"/>

                <!-- ── Custom folders ── -->
                <DockPanel Margin="2,0,0,6">
                    <TextBlock Text="Custom folders" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <ui:Button x:Name="EditLocationBtn" Icon="{ui:SymbolIcon Settings24}" Content="Configure"
                                   IsEnabled="False" Click="EditLocation_Click" Margin="0,0,8,0"/>
                        <ui:Button x:Name="RemoveLocationBtn" Appearance="Transparent" Icon="{ui:SymbolIcon Delete24}"
                                   IsEnabled="False" Click="RemoveLocation_Click" Margin="0,0,8,0"/>
                        <ui:Button Icon="{ui:SymbolIcon Add24}" Content="Add folder" Click="AddLocation_Click"/>
                    </StackPanel>
                </DockPanel>
                <ItemsControl x:Name="LocationsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:Card Margin="0,0,0,6" Padding="14,10"
                                     MouseLeftButtonUp="Location_Click" MouseDoubleClick="Location_DoubleClick">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Path}" FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <CheckBox Grid.Column="1" Content="Recency" VerticalAlignment="Center" Margin="12,0,12,0"
                                              IsChecked="{Binding Frecency, Mode=TwoWay}" Click="FolderRecency_Changed"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Status}" VerticalAlignment="Center"
                                               FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </Grid>
                            </ui:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
