<Page x:Class="BetterBarApp.Pages.LauncherItemPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:BetterBarApp.Controls"
      Title="Launcher">
    <Grid Margin="42,12,42,24" TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:Button Grid.Row="0" Appearance="Transparent" Icon="{ui:SymbolIcon ArrowLeft24}"
                   Content="Back" Click="Back_Click" Margin="0,0,0,8" HorizontalAlignment="Left"/>
        <TextBlock Grid.Row="1" Text="Launcher" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <ScrollViewer x:Name="PageScroll" Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <ui:CardControl Icon="{ui:SymbolIcon Folder24}" Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Source folder" FontWeight="SemiBold"/>
                            <TextBlock Text="Files in this folder become launcher icons."
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:TextBox x:Name="DirectoryBox" IsReadOnly="True" MinWidth="300" Margin="0,0,8,0"/>
                        <ui:Button Content="Browse…" Click="Browse_Click"/>
                    </StackPanel>
                </ui:CardControl>

                <ui:CardControl Icon="{ui:SymbolIcon TextBulletListLtr24}" Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <TextBlock Text="Rows" VerticalAlignment="Center"/>
                    </ui:CardControl.Header>
                    <controls:NumericBox x:Name="RowsBox" Minimum="1" Maximum="5" Step="1"
                                  MinWidth="120" ValueChanged="Changed"/>
                </ui:CardControl>

                <ui:CardControl Icon="{ui:SymbolIcon AutoFitWidth20}" Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <TextBlock Text="Icon spacing (px)" VerticalAlignment="Center"/>
                    </ui:CardControl.Header>
                    <controls:NumericBox x:Name="SpacingBox" Minimum="0" Maximum="40" Step="1"
                                  MinWidth="120" ValueChanged="Changed"/>
                </ui:CardControl>

                <ui:CardControl Icon="{ui:SymbolIcon Ruler24}" Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <TextBlock Text="Icon margin (px)" VerticalAlignment="Center"/>
                    </ui:CardControl.Header>
                    <controls:NumericBox x:Name="MarginBox" Minimum="0" Maximum="40" Step="1"
                                  MinWidth="120" ValueChanged="Changed"/>
                </ui:CardControl>

                <ui:CardControl Icon="{ui:SymbolIcon Comment24}" Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Show hover tooltips" VerticalAlignment="Center"/>
                            <TextBlock Text="Show the file name in a tip that follows the cursor while hovering an icon."
                                       FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:ToggleSwitch x:Name="TooltipsBox" Click="Changed"/>
                </ui:CardControl>

                <ui:CardControl Icon="{ui:SymbolIcon Timer24}">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Tooltip delay (ms)" VerticalAlignment="Center"/>
                            <TextBlock Text="How long to hover before the tip appears (only when tooltips are on)."
                                       FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <controls:NumericBox x:Name="TooltipDelayBox" Minimum="0" Maximum="5000" Step="100"
                                  MinWidth="120" ValueChanged="Changed"/>
                </ui:CardControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
