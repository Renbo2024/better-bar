<Page x:Class="BetterBarApp.Pages.WeatherPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:BetterBarApp.Controls"
      Title="Weather">
    <Grid Margin="42,12,42,24" TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:Button Grid.Row="0" Appearance="Transparent" Icon="{ui:SymbolIcon ArrowLeft24}"
                   Content="Back" Click="Back_Click" Margin="0,0,0,8" HorizontalAlignment="Left"/>
        <TextBlock Grid.Row="1" Text="Weather" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <ScrollViewer x:Name="PageScroll" Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ── Location ── -->
                <TextBlock Text="Location" FontWeight="SemiBold" Margin="2,0,0,6"/>
                <ui:CardControl Icon="{ui:SymbolIcon Location24}">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Selected location" VerticalAlignment="Center"/>
                            <TextBlock x:Name="CurrentLocationText" Text="No location selected"
                                       FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:Button Content="Change…" Icon="{ui:SymbolIcon Search24}" Click="ChangeLocation_Click"/>
                </ui:CardControl>

                <!-- ── Title ── -->
                <TextBlock Text="Title" FontWeight="SemiBold" Margin="2,12,0,6"/>
                <ui:CardControl Icon="{ui:SymbolIcon TextField24}" Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Show title" VerticalAlignment="Center"/>
                            <TextBlock Text="Show the title row across the top of the item."
                                       FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:ToggleSwitch x:Name="ShowTitleBox" Click="Changed"/>
                </ui:CardControl>
                <ui:CardControl Icon="{ui:SymbolIcon TextField24}">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Custom title" VerticalAlignment="Center"/>
                            <TextBlock Text="Leave blank to use the location name."
                                       FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:TextBox x:Name="TitleBox" MinWidth="220" TextChanged="Changed"/>
                </ui:CardControl>

                <!-- ── Units ── -->
                <TextBlock Text="Units" FontWeight="SemiBold" Margin="2,12,0,6"/>
                <ui:CardControl Icon="{ui:SymbolIcon Temperature24}">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Unit system" VerticalAlignment="Center"/>
                            <TextBlock Text="Metric (°C, km/h, mm/cm) or Imperial (°F, mph, in)."
                                       FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ComboBox x:Name="UnitsCombo" MinWidth="160" SelectionChanged="Changed">
                        <ComboBoxItem Content="Metric (°C)"/>
                        <ComboBoxItem Content="Imperial (°F)"/>
                    </ComboBox>
                </ui:CardControl>

                <!-- ── Forecast section ── -->
                <TextBlock Text="Forecast section" FontWeight="SemiBold" Margin="2,12,0,6"/>
                <ui:CardControl Icon="{ui:SymbolIcon WeatherPartlyCloudyDay24}" Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Show a Forecast section" VerticalAlignment="Center"/>
                            <TextBlock Text="Adds a second section beside Current, showing the worst condition expected ahead."
                                       FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:ToggleSwitch x:Name="ShowForecastBox" Click="Changed"/>
                </ui:CardControl>
                <ui:CardControl Icon="{ui:SymbolIcon CalendarClock24}">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Look ahead by" VerticalAlignment="Center"/>
                            <TextBlock Text="Hours, or whole days (1 day = Tomorrow). Sets the section label."
                                       FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <StackPanel Orientation="Horizontal">
                        <ComboBox x:Name="ForecastKindCombo" MinWidth="120" Margin="0,0,8,0" SelectionChanged="Changed">
                            <ComboBoxItem Content="Hours"/>
                            <ComboBoxItem Content="Days"/>
                        </ComboBox>
                        <controls:NumericBox x:Name="ForecastAmountBox" Minimum="1" Maximum="24" Step="1"
                                             Width="100" ValueChanged="Changed"/>
                    </StackPanel>
                </ui:CardControl>

                <!-- ── Tooltip ── -->
                <TextBlock Text="Tooltip" FontWeight="SemiBold" Margin="2,12,0,6"/>
                <ui:CardControl Icon="{ui:SymbolIcon Comment24}" Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Show hover tooltip" VerticalAlignment="Center"/>
                            <TextBlock Text="Hovering a section reveals extra detail (feels-like, wind, precipitation)."
                                       FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:ToggleSwitch x:Name="ShowTooltipBox" Click="Changed"/>
                </ui:CardControl>
                <ui:CardControl Icon="{ui:SymbolIcon Timer24}">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Tooltip delay (ms)" VerticalAlignment="Center"/>
                            <TextBlock Text="How long to hover before the tooltip appears."
                                       FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <controls:NumericBox x:Name="TooltipDelayBox" Minimum="0" Maximum="3000" Step="50" MinWidth="120" ValueChanged="Changed"/>
                </ui:CardControl>

                <!-- ── Fonts (face + size) ── -->
                <TextBlock Text="Fonts" FontWeight="SemiBold" Margin="2,12,0,6"/>
                <ui:CardControl Icon="{ui:SymbolIcon TextFont24}" Margin="0,0,0,8">
                    <ui:CardControl.Header><TextBlock Text="Title font" VerticalAlignment="Center"/></ui:CardControl.Header>
                    <StackPanel Orientation="Horizontal">
                        <ComboBox x:Name="TitleFontCombo" Width="180" Margin="0,0,8,0" SelectionChanged="Changed"/>
                        <controls:NumericBox x:Name="TitleSizeBox" Minimum="6" Maximum="48" Step="1" Width="90" ValueChanged="Changed"/>
                    </StackPanel>
                </ui:CardControl>
                <ui:CardControl Icon="{ui:SymbolIcon TextFont24}" Margin="0,0,0,8">
                    <ui:CardControl.Header><TextBlock Text="Measurement font" VerticalAlignment="Center"/></ui:CardControl.Header>
                    <StackPanel Orientation="Horizontal">
                        <ComboBox x:Name="MeasureFontCombo" Width="180" Margin="0,0,8,0" SelectionChanged="Changed"/>
                        <controls:NumericBox x:Name="MeasureSizeBox" Minimum="6" Maximum="48" Step="1" Width="90" ValueChanged="Changed"/>
                    </StackPanel>
                </ui:CardControl>
                <ui:CardControl Icon="{ui:SymbolIcon TextFont24}">
                    <ui:CardControl.Header><TextBlock Text="Label font" VerticalAlignment="Center"/></ui:CardControl.Header>
                    <StackPanel Orientation="Horizontal">
                        <ComboBox x:Name="LabelFontCombo" Width="180" Margin="0,0,8,0" SelectionChanged="Changed"/>
                        <controls:NumericBox x:Name="LabelSizeBox" Minimum="6" Maximum="32" Step="1" Width="90" ValueChanged="Changed"/>
                    </StackPanel>
                </ui:CardControl>

                <!-- ── Appearance ── -->
                <TextBlock Text="Appearance" FontWeight="SemiBold" Margin="2,12,0,6"/>
                <ui:CardControl Icon="{ui:SymbolIcon WeatherPartlyCloudyDay24}" Margin="0,0,0,8">
                    <ui:CardControl.Header><TextBlock Text="Icon size (px)" VerticalAlignment="Center"/></ui:CardControl.Header>
                    <controls:NumericBox x:Name="IconSizeBox" Minimum="8" Maximum="64" Step="1" MinWidth="120" ValueChanged="Changed"/>
                </ui:CardControl>
                <ui:CardControl Icon="{ui:SymbolIcon AutoFitWidth24}" Margin="0,0,0,8">
                    <ui:CardControl.Header><TextBlock Text="Space between sections (px)" VerticalAlignment="Center"/></ui:CardControl.Header>
                    <controls:NumericBox x:Name="SectionSpacingBox" Minimum="0" Maximum="60" Step="1" MinWidth="120" ValueChanged="Changed"/>
                </ui:CardControl>
                <ui:CardControl Icon="{ui:SymbolIcon ResizeLarge24}" Margin="0,0,0,8">
                    <ui:CardControl.Header><TextBlock Text="Outer horizontal margin (px)" VerticalAlignment="Center"/></ui:CardControl.Header>
                    <controls:NumericBox x:Name="MarginBox" Minimum="0" Maximum="60" Step="1" MinWidth="120" ValueChanged="Changed"/>
                </ui:CardControl>
                <ui:CardControl Icon="{ui:SymbolIcon Color24}">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Text color" VerticalAlignment="Center"/>
                            <TextBlock Text="Default uses the bar's text color."
                                       FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <controls:ColorPickerButton x:Name="TextColorPicker" ValueChanged="Changed"/>
                </ui:CardControl>

                <!-- ── Refresh ── -->
                <TextBlock Text="Updates" FontWeight="SemiBold" Margin="2,12,0,6"/>
                <ui:CardControl Icon="{ui:SymbolIcon ArrowClockwise24}">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Refresh interval (minutes)" VerticalAlignment="Center"/>
                            <TextBlock Text="How often the bar re-fetches the forecast."
                                       FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <controls:NumericBox x:Name="RefreshBox" Minimum="1" Maximum="180" Step="1" MinWidth="120" ValueChanged="Changed"/>
                </ui:CardControl>

                <TextBlock Text="Weather data by Open-Meteo.com (CC BY 4.0)."
                           FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="2,14,0,0"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
