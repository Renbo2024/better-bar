<Page x:Class="BetterBarApp.Pages.BarsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Bars">
    <Grid Margin="42,12,42,24" TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Bars"
                   FontSize="28" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1"
                   Text="A bar definition is a reusable layout (height + items). Place it on one or more monitors from its editor."
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,16"/>

        <DockPanel Grid.Row="2">
            <ui:Button DockPanel.Dock="Top" x:Name="AddBtn"
                       Appearance="Primary" Icon="{ui:SymbolIcon Add24}"
                       Content="New bar" Click="New_Click"
                       Margin="0,0,0,12" HorizontalAlignment="Left"/>

            <ScrollViewer x:Name="PageScroll" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="DefinitionList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:CardControl Margin="0,0,0,8" MouseDoubleClick="Card_DoubleClick">
                                <ui:CardControl.Icon>
                                    <ui:SymbolIcon Symbol="Window24"/>
                                </ui:CardControl.Icon>
                                <ui:CardControl.Header>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"/>
                                        <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   FontSize="12">
                                            <Run Text="{Binding HeightPx, Mode=OneWay}"/><Run Text="px tall"/>
                                        </TextBlock>
                                    </StackPanel>
                                </ui:CardControl.Header>
                                <StackPanel Orientation="Horizontal">
                                    <ui:Button Icon="{ui:SymbolIcon Edit24}" Content="Edit"
                                               Click="Edit_Click" Margin="0,0,8,0"/>
                                    <ui:Button Icon="{ui:SymbolIcon Copy24}" Content="Clone"
                                               Click="Clone_Click" Margin="0,0,8,0"/>
                                    <ui:Button Icon="{ui:SymbolIcon Delete24}"
                                               Click="Delete_Click"/>
                                </StackPanel>
                            </ui:CardControl>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</Page>
