<Page x:Class="BetterBarApp.Pages.ClockPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:BetterBarApp.Controls"
      Title="Clock">
    <Grid Margin="42,12,42,24" TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:Button Grid.Row="0" Appearance="Transparent" Icon="{ui:SymbolIcon ArrowLeft24}"
                   Content="Back" Click="Back_Click" Margin="0,0,0,8" HorizontalAlignment="Left"/>
        <TextBlock Grid.Row="1" Text="Clock" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <ScrollViewer x:Name="PageScroll" Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ── Show ── -->
                <TextBlock Text="Show" FontWeight="SemiBold" Margin="2,0,0,6"/>
                <ui:CardControl Icon="{ui:SymbolIcon Ruler24}" Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Margin (px)" FontWeight="SemiBold"/>
                            <TextBlock Text="Space on each side of the clock text."
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <controls:NumericBox x:Name="MarginBox" Minimum="0" Maximum="60" Step="1"
                                  MinWidth="120" ValueChanged="Changed"/>
                </ui:CardControl>
                <ui:CardControl Icon="{ui:SymbolIcon Clock24}" Margin="0,0,0,8">
                    <ui:CardControl.Header><TextBlock Text="Time" VerticalAlignment="Center"/></ui:CardControl.Header>
                    <ui:ToggleSwitch x:Name="ShowTimeBox" Click="Changed"/>
                </ui:CardControl>
                <ui:CardControl Icon="{ui:SymbolIcon CalendarLtr24}" Margin="0,0,0,8">
                    <ui:CardControl.Header><TextBlock Text="Date" VerticalAlignment="Center"/></ui:CardControl.Header>
                    <ui:ToggleSwitch x:Name="ShowDateBox" Click="Changed"/>
                </ui:CardControl>
                <ui:CardControl Icon="{ui:SymbolIcon Globe24}" Margin="0,0,0,8">
                    <ui:CardControl.Header><TextBlock Text="Time zone name" VerticalAlignment="Center"/></ui:CardControl.Header>
                    <ui:ToggleSwitch x:Name="ShowZoneBox" Click="Changed"/>
                </ui:CardControl>
                <ui:CardControl Icon="{ui:SymbolIcon Rename24}" Margin="0,0,0,16">
                    <ui:CardControl.Header><TextBlock Text="Title" VerticalAlignment="Center"/></ui:CardControl.Header>
                    <ui:ToggleSwitch x:Name="ShowTitleBox" Click="Changed"/>
                </ui:CardControl>

                <!-- ── Time format ── -->
                <TextBlock Text="Time" FontWeight="SemiBold" Margin="2,0,0,6"/>
                <ui:CardControl Margin="0,0,0,8">
                    <ui:CardControl.Header><TextBlock Text="24-hour clock" VerticalAlignment="Center"/></ui:CardControl.Header>
                    <ui:ToggleSwitch x:Name="Use24Box" Click="Changed"/>
                </ui:CardControl>
                <ui:CardControl Margin="0,0,0,8">
                    <ui:CardControl.Header><TextBlock Text="Show seconds" VerticalAlignment="Center"/></ui:CardControl.Header>
                    <ui:ToggleSwitch x:Name="SecondsBox" Click="Changed"/>
                </ui:CardControl>
                <ui:CardControl Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Show AM/PM" FontWeight="SemiBold"/>
                            <TextBlock Text="Only applies to the 12-hour clock."
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:ToggleSwitch x:Name="AmPmBox" Click="Changed"/>
                </ui:CardControl>
                <ui:CardControl Margin="0,0,0,8">
                    <ui:CardControl.Header><TextBlock Text="Leading zero on hour" VerticalAlignment="Center"/></ui:CardControl.Header>
                    <ui:ToggleSwitch x:Name="HourZeroBox" Click="Changed"/>
                </ui:CardControl>
                <ui:CardControl Icon="{ui:SymbolIcon TextFont24}" Margin="0,0,0,16">
                    <ui:CardControl.Header><TextBlock Text="Time font" VerticalAlignment="Center"/></ui:CardControl.Header>
                    <StackPanel Orientation="Horizontal">
                        <ComboBox x:Name="TimeFontCombo" Width="170" Margin="0,0,8,0" SelectionChanged="Changed"/>
                        <controls:NumericBox x:Name="TimeSizeBox" Minimum="6" Maximum="72" Step="1"
                                      Width="90" Margin="0,0,8,0" ValueChanged="Changed"/>
                        <ui:ToggleSwitch x:Name="TimeBoldBox" Content="Bold" Margin="0,0,8,0" Click="Changed"/>
                        <ui:ToggleSwitch x:Name="TimeItalicBox" Content="Italic" Margin="0,0,8,0" Click="Changed"/>
                        <controls:ColorPickerButton x:Name="TimeColorPicker" ValueChanged="Changed"/>
                    </StackPanel>
                </ui:CardControl>

                <!-- ── Date format ── -->
                <TextBlock Text="Date" FontWeight="SemiBold" Margin="2,0,0,6"/>
                <ui:CardControl Margin="0,0,0,8">
                    <ui:CardControl.Header><TextBlock Text="Day of week" VerticalAlignment="Center"/></ui:CardControl.Header>
                    <ComboBox x:Name="WeekdayCombo" MinWidth="160" SelectionChanged="Changed">
                        <ComboBoxItem Content="Don't show"/>
                        <ComboBoxItem Content="Short (Mon)"/>
                        <ComboBoxItem Content="Full (Monday)"/>
                    </ComboBox>
                </ui:CardControl>
                <ui:CardControl Margin="0,0,0,8">
                    <ui:CardControl.Header><TextBlock Text="Month" VerticalAlignment="Center"/></ui:CardControl.Header>
                    <ComboBox x:Name="MonthCombo" MinWidth="160" SelectionChanged="Changed">
                        <ComboBoxItem Content="Number (1)"/>
                        <ComboBoxItem Content="Number, padded (01)"/>
                        <ComboBoxItem Content="Short name (Jan)"/>
                        <ComboBoxItem Content="Full name (January)"/>
                    </ComboBox>
                </ui:CardControl>
                <ui:CardControl Margin="0,0,0,8">
                    <ui:CardControl.Header><TextBlock Text="Leading zero on day" VerticalAlignment="Center"/></ui:CardControl.Header>
                    <ui:ToggleSwitch x:Name="DayZeroBox" Click="Changed"/>
                </ui:CardControl>
                <ui:CardControl Margin="0,0,0,8">
                    <ui:CardControl.Header><TextBlock Text="Year" VerticalAlignment="Center"/></ui:CardControl.Header>
                    <ComboBox x:Name="YearCombo" MinWidth="160" SelectionChanged="Changed">
                        <ComboBoxItem Content="Don't show"/>
                        <ComboBoxItem Content="Two digits (26)"/>
                        <ComboBoxItem Content="Four digits (2026)"/>
                    </ComboBox>
                </ui:CardControl>
                <ui:CardControl Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Day before month" FontWeight="SemiBold"/>
                            <TextBlock Text="e.g. 5 Jan instead of Jan 5."
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:ToggleSwitch x:Name="DayBeforeMonthBox" Click="Changed"/>
                </ui:CardControl>
                <ui:CardControl Icon="{ui:SymbolIcon TextFont24}">
                    <ui:CardControl.Header><TextBlock Text="Date font" VerticalAlignment="Center"/></ui:CardControl.Header>
                    <StackPanel Orientation="Horizontal">
                        <ComboBox x:Name="DateFontCombo" Width="170" Margin="0,0,8,0" SelectionChanged="Changed"/>
                        <controls:NumericBox x:Name="DateSizeBox" Minimum="6" Maximum="72" Step="1"
                                      Width="90" Margin="0,0,8,0" ValueChanged="Changed"/>
                        <ui:ToggleSwitch x:Name="DateBoldBox" Content="Bold" Margin="0,0,8,0" Click="Changed"/>
                        <ui:ToggleSwitch x:Name="DateItalicBox" Content="Italic" Margin="0,0,8,0" Click="Changed"/>
                        <controls:ColorPickerButton x:Name="DateColorPicker" ValueChanged="Changed"/>
                    </StackPanel>
                </ui:CardControl>

                <!-- ── Time zone ── -->
                <TextBlock Text="Time zone" FontWeight="SemiBold" Margin="2,16,0,6"/>
                <ui:CardControl Icon="{ui:SymbolIcon Globe24}" Margin="0,0,0,8">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="Time zone" FontWeight="SemiBold"/>
                            <TextBlock Text="Show this clock in a specific zone instead of the computer's."
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ComboBox x:Name="ZoneCombo" MinWidth="320" MaxDropDownHeight="320"
                              IsEditable="True" StaysOpenOnEdit="True" IsTextSearchEnabled="False"
                              SelectionChanged="Changed"/>
                </ui:CardControl>
                <ui:CardControl Icon="{ui:SymbolIcon TextFont24}" Margin="0,0,0,16">
                    <ui:CardControl.Header><TextBlock Text="Time zone name font" VerticalAlignment="Center"/></ui:CardControl.Header>
                    <StackPanel Orientation="Horizontal">
                        <ComboBox x:Name="ZoneFontCombo" Width="170" Margin="0,0,8,0" SelectionChanged="Changed"/>
                        <controls:NumericBox x:Name="ZoneSizeBox" Minimum="6" Maximum="72" Step="1"
                                      Width="90" Margin="0,0,8,0" ValueChanged="Changed"/>
                        <ui:ToggleSwitch x:Name="ZoneBoldBox" Content="Bold" Margin="0,0,8,0" Click="Changed"/>
                        <ui:ToggleSwitch x:Name="ZoneItalicBox" Content="Italic" Margin="0,0,8,0" Click="Changed"/>
                        <controls:ColorPickerButton x:Name="ZoneColorPicker" ValueChanged="Changed"/>
                    </StackPanel>
                </ui:CardControl>

                <!-- ── Title ── -->
                <TextBlock Text="Title" FontWeight="SemiBold" Margin="2,16,0,6"/>
                <ui:CardControl Icon="{ui:SymbolIcon Rename24}" Margin="0,0,0,8">
                    <ui:CardControl.Header><TextBlock Text="Text" VerticalAlignment="Center"/></ui:CardControl.Header>
                    <ui:TextBox x:Name="TitleBox" MinWidth="240" TextChanged="Changed"/>
                </ui:CardControl>
                <ui:CardControl Icon="{ui:SymbolIcon TextFont24}" Margin="0,0,0,16">
                    <ui:CardControl.Header><TextBlock Text="Title font" VerticalAlignment="Center"/></ui:CardControl.Header>
                    <StackPanel Orientation="Horizontal">
                        <ComboBox x:Name="TitleFontCombo" Width="170" Margin="0,0,8,0" SelectionChanged="Changed"/>
                        <controls:NumericBox x:Name="TitleSizeBox" Minimum="6" Maximum="72" Step="1"
                                      Width="90" Margin="0,0,8,0" ValueChanged="Changed"/>
                        <ui:ToggleSwitch x:Name="TitleBoldBox" Content="Bold" Margin="0,0,8,0" Click="Changed"/>
                        <ui:ToggleSwitch x:Name="TitleItalicBox" Content="Italic" Margin="0,0,8,0" Click="Changed"/>
                        <controls:ColorPickerButton x:Name="TitleColorPicker" ValueChanged="Changed"/>
                    </StackPanel>
                </ui:CardControl>

                <!-- ── Line order ── -->
                <TextBlock Text="Line order" FontWeight="SemiBold" Margin="2,0,0,6"/>
                <TextBlock Text="Top-to-bottom order of the lines (only the enabled ones show)."
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="2,0,0,8"/>
                <ui:Card Padding="8">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0,0,0">
                            <ui:Button x:Name="OrderUpBtn" Icon="{ui:SymbolIcon ArrowUp24}"
                                       Click="OrderUp_Click" Margin="0,0,0,4" IsEnabled="False"/>
                            <ui:Button x:Name="OrderDownBtn" Icon="{ui:SymbolIcon ArrowDown24}"
                                       Click="OrderDown_Click" IsEnabled="False"/>
                        </StackPanel>
                        <ListBox x:Name="OrderList" Height="116"
                                 SelectionChanged="OrderList_SelectionChanged"/>
                    </DockPanel>
                </ui:Card>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
