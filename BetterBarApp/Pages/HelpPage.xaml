<Page x:Class="BetterBarApp.Pages.HelpPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mdxam="clr-namespace:MdXaml;assembly=MdXaml"
      Title="Help">
    <Grid Margin="24,12,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page title uses the settings (themed) chrome. -->
        <TextBlock Grid.Row="0" Text="Help" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,12"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

        <!-- The README renders into its OWN neutral, un-themed light "document" surface. MdXaml's
             default element styling (code blocks, tables, blockquotes, links) is designed for a light
             page, so the app theme is deliberately kept out of this area to avoid dark-on-dark chunks.
             Foreground/Background are fixed here and NOT bound to any theme resource. -->
        <Border Grid.Row="1" Background="#FFFFFFFF" CornerRadius="6" Padding="8">
            <mdxam:MarkdownScrollViewer x:Name="Viewer"
                                        Background="Transparent"
                                        Foreground="#FF1B1B1B"
                                        VerticalScrollBarVisibility="Auto"
                                        TextElement.Foreground="#FF1B1B1B"/>
        </Border>
    </Grid>
</Page>
