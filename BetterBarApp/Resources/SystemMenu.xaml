<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        System-style context menu for taskbar buttons. Mirrors the Windows window menu's look
        (rounded dark surface, themed via the palette keys) and uses Marlett-font glyphs for the
        window actions, the way RetroBar does: Restore '2', Minimize '0', Maximize '1', Close 'r'.
        Applied explicitly in code (menu.Style / item.Style) so it doesn't affect other menus.
    -->

    <Style x:Key="SystemMenuItem" TargetType="MenuItem">
        <Setter Property="Foreground" Value="{DynamicResource TaskBtnFg}"/>
        <Setter Property="Height"     Value="30"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="Bd" Background="Transparent" CornerRadius="4"
                            Margin="3,1" Padding="6,0" SnapsToDevicePixels="True"
                            TextElement.Foreground="{TemplateBinding Foreground}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ContentPresenter x:Name="Icon" Grid.Column="0" ContentSource="Icon"
                                              Width="16" Height="16"
                                              VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <ContentPresenter Grid.Column="1" ContentSource="Header" RecognizesAccessKey="True"
                                              VerticalAlignment="Center" Margin="8,0,16,0"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource TaskBtnHoverBg}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                            <Setter TargetName="Icon" Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SystemMenuSeparator" TargetType="Separator">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Border Height="1" Background="{DynamicResource PanelSeparator}" Margin="10,4"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SystemContextMenu" TargetType="ContextMenu">
        <Setter Property="Foreground"   Value="{DynamicResource TaskBtnFg}"/>
        <Setter Property="HasDropShadow" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="{DynamicResource StartMenuBg}"
                            BorderBrush="{DynamicResource StartMenuBorder}" BorderThickness="1"
                            CornerRadius="8" Padding="3" SnapsToDevicePixels="True">
                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
