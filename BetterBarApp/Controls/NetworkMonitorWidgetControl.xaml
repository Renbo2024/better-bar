<UserControl x:Class="BetterBarApp.Controls.NetworkMonitorWidgetControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:BetterBarApp.Controls"
             VerticalAlignment="Stretch">
    <!-- Graph fills the cell; title/subtitle are painted over the top/bottom of it. -->
    <Grid>
        <controls:NetworkGraph x:Name="Graph"/>
        <controls:OutlinedTextBlock x:Name="TitleText"    VerticalAlignment="Top"    HorizontalAlignment="Stretch"
                   TextAlignment="Center" Visibility="Collapsed"/>
        <controls:OutlinedTextBlock x:Name="SubtitleText" VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                   TextAlignment="Center" Visibility="Collapsed"/>
    </Grid>
</UserControl>
