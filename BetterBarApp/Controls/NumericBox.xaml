<UserControl x:Class="BetterBarApp.Controls.NumericBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="32" MinWidth="90">
    <!-- Styled for the dark settings surface (this control is used only there). -->
    <UserControl.Resources>

        <Style x:Key="InnerTextBox" TargetType="TextBox">
            <Setter Property="Background"               Value="Transparent"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="Padding"                  Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="Foreground"               Value="#FFF0F0F0"/>
            <Setter Property="CaretBrush"               Value="#FFF0F0F0"/>
            <Setter Property="SelectionBrush"           Value="#FF0078D4"/>
            <Setter Property="FocusVisualStyle"         Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Focusable="False"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SpinBtn" TargetType="RepeatButton">
            <Setter Property="MinWidth"         Value="0"/>
            <Setter Property="MinHeight"        Value="0"/>
            <Setter Property="Padding"          Value="0"/>
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Foreground"       Value="#FFC0C0C0"/>
            <Setter Property="FontSize"         Value="7"/>
            <Setter Property="Cursor"           Value="Arrow"/>
            <Setter Property="Delay"            Value="400"/>
            <Setter Property="Interval"         Value="80"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Border x:Name="OuterBorder"
            Background="#FF2B2B2B"
            BorderBrush="#FF5A5A5A"
            BorderThickness="1"
            CornerRadius="4"
            SnapsToDevicePixels="True"
            ClipToBounds="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="22"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     x:Name="ValueBox"
                     Style="{StaticResource InnerTextBox}"
                     TextChanged="ValueBox_TextChanged"
                     PreviewKeyDown="ValueBox_PreviewKeyDown"
                     GotFocus="ValueBox_GotFocus"
                     LostFocus="ValueBox_LostFocus"/>

            <Border Grid.Column="1" BorderBrush="#FF5A5A5A" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <RepeatButton Grid.Row="0" Style="{StaticResource SpinBtn}" Content="▲"
                                  BorderBrush="#FF5A5A5A" BorderThickness="0,0,0,1" Click="UpBtn_Click"/>
                    <RepeatButton Grid.Row="1" Style="{StaticResource SpinBtn}" Content="▼" Click="DownBtn_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
