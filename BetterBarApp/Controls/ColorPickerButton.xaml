<UserControl x:Class="BetterBarApp.Controls.ColorPickerButton"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cp="clr-namespace:ColorPicker;assembly=ColorPicker">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid>
        <ToggleButton x:Name="Toggle" Padding="8,4" Cursor="Hand">
            <StackPanel Orientation="Horizontal">
                <Border x:Name="Swatch" Width="16" Height="16" CornerRadius="3"
                        BorderBrush="#80808080" BorderThickness="1" Margin="0,0,6,0"/>
                <TextBlock x:Name="Label" Text="Default" VerticalAlignment="Center"/>
            </StackPanel>
        </ToggleButton>

        <Popup x:Name="Pop" StaysOpen="False" AllowsTransparency="True"
               Placement="Bottom" PlacementTarget="{Binding ElementName=Toggle}"
               IsOpen="{Binding IsChecked, ElementName=Toggle, Mode=TwoWay}">
            <Border Background="{DynamicResource ApplicationBackgroundBrush}"
                    BorderBrush="#40808080" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,4,0,0">
                <StackPanel TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                    <CheckBox x:Name="DefaultBox" Content="Use default (theme) color"
                              Margin="0,0,0,10" Click="DefaultBox_Click"
                              Visibility="{Binding AllowDefault, ElementName=Root, Converter={StaticResource BoolToVis}}"/>
                    <!-- Let the picker take its natural size; constraining its width makes
                         the hex/numeric fields overlap. -->
                    <cp:StandardColorPicker x:Name="Picker"
                        Width="336" ShowAlpha="{Binding ShowAlpha, ElementName=Root}" SmallChange="1"
                        HorizontalAlignment="Left"
                        SelectedColor="{Binding PickedColor, ElementName=Root, Mode=TwoWay}"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
