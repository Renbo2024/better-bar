<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    mc:Ignorable="po">

    <!--
        ================= THEME: Light =================
        The inverse of the Dark theme: light surfaces with darker foregrounds. Blue is still used
        for the accent, selection, and the focused task button. Same key set as Themes/Dark.xaml.
        Overlays on the light bar are translucent BLACK (instead of Dark's translucent white) so
        hover/active read correctly on a pale surface.
    -->

    <!-- Marker used by ThemeService to locate the active theme dictionary. -->
    <sys:String x:Key="ThemeName">Light</sys:String>

    <!-- ===== Panel surface (muted soft grey — deliberately not bright white) ===== -->
    <SolidColorBrush x:Key="PanelBackground" Color="#DCDCDC" po:Freeze="True"/>

    <!-- ===== Task button corner radius (gently rounded for the lighter look) ===== -->
    <CornerRadius x:Key="TaskButtonCornerRadius">4</CornerRadius>

    <!-- ===== Core palette — muted light surfaces, softened (not pure-black) text, blue accent ===== -->
    <SolidColorBrush x:Key="WindowBg"      Color="#E0E0E0" po:Freeze="True"/>
    <SolidColorBrush x:Key="SurfaceBg"     Color="#EBEBEB" po:Freeze="True"/>
    <SolidColorBrush x:Key="CtrlBorder"    Color="#BFBFBF" po:Freeze="True"/>
    <SolidColorBrush x:Key="Accent"        Color="#0078D4" po:Freeze="True"/>
    <SolidColorBrush x:Key="AccentHover"   Color="#106EBE" po:Freeze="True"/>
    <SolidColorBrush x:Key="AccentPress"   Color="#005A9E" po:Freeze="True"/>
    <SolidColorBrush x:Key="TextPrimary"   Color="#2B2B2B" po:Freeze="True"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#6A6A6A" po:Freeze="True"/>
    <SolidColorBrush x:Key="ItemHover"     Color="#DAE6F2" po:Freeze="True"/>
    <SolidColorBrush x:Key="ItemSelected"  Color="#C6DCEF" po:Freeze="True"/>

    <!-- ===== Panel separator line (subtle dark rim on the light bar) ===== -->
    <SolidColorBrush x:Key="PanelSeparator" Color="#1F000000" po:Freeze="True"/>

    <!-- ===== Start menu (muted light surface with a soft dark rim) ===== -->
    <SolidColorBrush x:Key="StartMenuBg"      Color="#E0E0E0" po:Freeze="True"/>
    <SolidColorBrush x:Key="StartMenuBorder"  Color="#22000000" po:Freeze="True"/>
    <SolidColorBrush x:Key="StartMenuFieldBg" Color="#EBEBEB" po:Freeze="True"/>

    <!-- ===== Task button brushes. TaskBtnFg colours the bar text AND the Start glyph; kept a softer
              dark grey (not near-black) so the Start button reads a little less dark. ===== -->
    <SolidColorBrush x:Key="TaskBtnFg"       Color="#3D3D3D" po:Freeze="True"/>
    <SolidColorBrush x:Key="TaskBtnHoverBg"  Color="#12000000" po:Freeze="True"/>
    <SolidColorBrush x:Key="TaskBtnActiveBg" Color="#1E0078D4" po:Freeze="True"/>

    <!-- ===== Default accent-bar colour for running (unfocused) buttons: a muted grey that
              reads against the muted light bar ===== -->
    <SolidColorBrush x:Key="TaskBtnUnselectedAccent" Color="#A6A6A6" po:Freeze="True"/>

</ResourceDictionary>
