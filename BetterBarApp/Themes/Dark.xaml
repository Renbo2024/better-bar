<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    mc:Ignorable="po">

    <!--
        ================= THEME: Dark =================
        This dictionary is the swappable colour palette. App.xaml merges it as the
        active theme; ThemeService replaces it (matched by the ThemeName marker)
        when the user picks another theme. Styles in Resources/Win11Styles.xaml
        reference these keys via DynamicResource, so a swap re-colours every panel
        and item live. To add a theme, copy this file, change the values and the
        ThemeName, and register it in ThemeService.Available.
        The Dark theme is also the canonical full key set (ThemeService baseline).
    -->

    <!-- Marker used by ThemeService to locate the active theme dictionary. -->
    <sys:String x:Key="ThemeName">Dark</sys:String>

    <!-- ===== Panel surface (uniform, no gradient) ===== -->
    <SolidColorBrush x:Key="PanelBackground" Color="#1C1C1C" po:Freeze="True"/>

    <!-- ===== Task button corner radius (0 = square corners) ===== -->
    <CornerRadius x:Key="TaskButtonCornerRadius">0</CornerRadius>

    <!-- ===== Core palette (frozen — no bindings/animations, safe to freeze) ===== -->
    <SolidColorBrush x:Key="WindowBg"      Color="#F3F3F3" po:Freeze="True"/>
    <SolidColorBrush x:Key="SurfaceBg"     Color="#FFFFFF"  po:Freeze="True"/>
    <SolidColorBrush x:Key="CtrlBorder"    Color="#DEDEDE"  po:Freeze="True"/>
    <SolidColorBrush x:Key="Accent"        Color="#0078D4"  po:Freeze="True"/>
    <SolidColorBrush x:Key="AccentHover"   Color="#106EBE"  po:Freeze="True"/>
    <SolidColorBrush x:Key="AccentPress"   Color="#005A9E"  po:Freeze="True"/>
    <SolidColorBrush x:Key="TextPrimary"   Color="#1C1C1C"  po:Freeze="True"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#636363"  po:Freeze="True"/>
    <SolidColorBrush x:Key="ItemHover"     Color="#EAEAEA"  po:Freeze="True"/>
    <SolidColorBrush x:Key="ItemSelected"  Color="#E3F2FF"  po:Freeze="True"/>

    <!-- ===== Panel separator line (sits on the dark panel) ===== -->
    <SolidColorBrush x:Key="PanelSeparator" Color="#59FFFFFF" po:Freeze="True"/>

    <!-- ===== Start menu (dark Win11 surface; matches the settings app's dark grey) ===== -->
    <SolidColorBrush x:Key="StartMenuBg"      Color="#202020" po:Freeze="True"/>
    <SolidColorBrush x:Key="StartMenuBorder"  Color="#33FFFFFF" po:Freeze="True"/>
    <SolidColorBrush x:Key="StartMenuFieldBg" Color="#2B2B2B" po:Freeze="True"/>

    <!-- ===== Task button brushes (sit on the dark panel) ===== -->
    <SolidColorBrush x:Key="TaskBtnFg"       Color="#E8E8E8" po:Freeze="True"/>
    <SolidColorBrush x:Key="TaskBtnHoverBg"  Color="#28FFFFFF" po:Freeze="True"/>
    <SolidColorBrush x:Key="TaskBtnActiveBg" Color="#3CFFFFFF" po:Freeze="True"/>

    <!-- ===== Default accent-bar colour for running (unfocused) buttons: a grey a little
              lighter than the panel, so it reads as "running but not focused" ===== -->
    <SolidColorBrush x:Key="TaskBtnUnselectedAccent" Color="#6E6E6E" po:Freeze="True"/>

</ResourceDictionary>
