<Window x:Class="BetterBarApp.Windows.WeatherFlyoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ResizeMode="NoResize" SizeToContent="WidthAndHeight"
        Topmost="True" WindowStartupLocation="Manual">
    <!--
        Weather flyout, opened by clicking a Weather bar item. Two tabs — Hourly and Daily (the last
        viewed one re-opens by default). Each tab shows a detail list on the left and line charts on
        the right, paged 6 (hourly) / 7 (daily) at a time with the ‹ › arrows through the whole range
        (48 hours / 14 days); the charts follow the current page. Themed via the active bar palette;
        slides + fades in/out (see code-behind). Rows and charts are built in code.
    -->
    <Window.Resources>
        <Style x:Key="NavBtn" TargetType="Border">
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TaskBtnHoverBg}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Border x:Name="Root" Margin="14" Opacity="0"
            Background="{DynamicResource StartMenuBg}"
            BorderBrush="{DynamicResource StartMenuBorder}" BorderThickness="1"
            CornerRadius="10" Padding="20,16,20,18">
        <Border.RenderTransform>
            <TranslateTransform x:Name="Slide"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.5" Color="#000000"/>
        </Border.Effect>
        <StackPanel>
            <TextBlock x:Name="HeaderText" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,2"
                       Foreground="{DynamicResource TaskBtnFg}"/>
            <TextBlock x:Name="SubText" FontSize="12.5" Opacity="0.75" Margin="0,0,0,2"
                       Foreground="{DynamicResource TaskBtnFg}" TextWrapping="Wrap"/>
            <TextBlock x:Name="NarrativeText" FontSize="12.5" Opacity="0.95" Margin="0,4,0,0"
                       Foreground="{DynamicResource Accent}" TextWrapping="Wrap" MaxWidth="520"/>

            <!-- Tabs -->
            <StackPanel Orientation="Horizontal" Margin="0,14,0,10">
                <Border x:Name="HourlyTab" CornerRadius="6" Padding="16,5" Margin="0,0,6,0" Cursor="Hand"
                        MouseLeftButtonUp="HourlyTab_Click">
                    <TextBlock x:Name="HourlyTabText" Text="Hourly" FontSize="13" FontWeight="SemiBold"/>
                </Border>
                <Border x:Name="DailyTab" CornerRadius="6" Padding="16,5" Cursor="Hand"
                        MouseLeftButtonUp="DailyTab_Click">
                    <TextBlock x:Name="DailyTabText" Text="Daily" FontSize="13" FontWeight="SemiBold"/>
                </Border>
            </StackPanel>

            <!-- Pager -->
            <DockPanel Margin="0,0,0,10">
                <Border x:Name="PrevBtn" Style="{StaticResource NavBtn}" DockPanel.Dock="Left"
                        MouseLeftButtonUp="Prev_Click" ToolTip="Earlier">
                    <ui:SymbolIcon Symbol="ChevronLeft24" FontSize="16" Foreground="{DynamicResource TaskBtnFg}"/>
                </Border>
                <Border x:Name="NextBtn" Style="{StaticResource NavBtn}" DockPanel.Dock="Right"
                        MouseLeftButtonUp="Next_Click" ToolTip="Later">
                    <ui:SymbolIcon Symbol="ChevronRight24" FontSize="16" Foreground="{DynamicResource TaskBtnFg}"/>
                </Border>
                <TextBlock x:Name="PageLabel" HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="12.5" Opacity="0.8" Foreground="{DynamicResource TaskBtnFg}"/>
            </DockPanel>

            <!-- Content: detail list + charts for the current page -->
            <StackPanel Orientation="Horizontal">
                <StackPanel x:Name="DetailList" MinWidth="208"/>
                <StackPanel x:Name="Charts" Margin="22,0,0,0"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
