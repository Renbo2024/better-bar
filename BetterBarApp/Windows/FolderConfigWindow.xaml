<Window x:Class="BetterBarApp.Windows.FolderConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Folder Settings"
        Icon="pack://application:,,,/app.ico"
        Width="520"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Win11Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <DockPanel Margin="24,20,24,20">

        <TextBlock DockPanel.Dock="Top"
                   Text="Search Folder"
                   FontFamily="Segoe UI Variable Display, Segoe UI"
                   FontSize="20" FontWeight="SemiBold"
                   Margin="0,0,0,16"/>

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="OK" Style="{StaticResource PrimaryButton}"
                    IsDefault="True" Margin="0,0,8,0" Click="OK_Click"/>
            <Button Content="Cancel" IsCancel="True" Click="Cancel_Click"/>
        </StackPanel>

        <Border Background="{StaticResource SurfaceBg}"
                BorderBrush="{StaticResource CtrlBorder}"
                BorderThickness="1" CornerRadius="8" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="Path"
                       VerticalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="PathText"
                           VerticalAlignment="Center" Margin="0,0,0,12"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{StaticResource TextSecondary}"/>

                <Label Grid.Row="1" Grid.Column="0" Content="Display name"
                       VerticalAlignment="Center" Margin="0,0,0,12"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="NameBox" Margin="0,0,0,12"/>

                <CheckBox Grid.Row="2" Grid.Column="1" x:Name="CascadeBox"
                          Content="Include subfolders" Margin="0,0,0,12"/>

                <CheckBox Grid.Row="3" Grid.Column="1" x:Name="FrecencyBox"
                          Content="Boost results I open often/recently (recency)"
                          Margin="0,0,0,12"/>

                <Label Grid.Row="4" Grid.Column="0" Content="Only include"
                       VerticalAlignment="Center" Margin="0,0,0,4"/>
                <TextBox Grid.Row="4" Grid.Column="1" x:Name="IncludeBox" Margin="0,0,0,4"
                         ToolTip="Regex matched against each file name. Blank = include everything."/>
                <TextBlock Grid.Row="5" Grid.Column="1"
                           Text="Regex; only files whose name matches are indexed."
                           FontSize="11" Foreground="{StaticResource TextSecondary}"
                           Margin="0,0,0,12"/>

                <Label Grid.Row="6" Grid.Column="0" Content="Always exclude"
                       VerticalAlignment="Center" Margin="0,0,0,4"/>
                <TextBox Grid.Row="6" Grid.Column="1" x:Name="ExcludeBox" Margin="0,0,0,4"
                         ToolTip="Regex matched against each file name. Blank = exclude nothing."/>
                <TextBlock Grid.Row="7" Grid.Column="1"
                           Text="Regex; files whose name matches are dropped (wins over Only include)."
                           FontSize="11" Foreground="{StaticResource TextSecondary}"/>
            </Grid>
        </Border>

    </DockPanel>
</Window>
