<Window x:Class="BetterBarApp.Windows.CalendarFlyoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ResizeMode="NoResize" SizeToContent="WidthAndHeight"
        Topmost="True" WindowStartupLocation="Manual">
    <!--
        Our own calendar popup, shown when the bar clock is clicked (replacing the native
        Windows date/time flyout). Follows the active bar theme via DynamicResource palette
        keys. It slides + fades in/out (see code-behind); clicking the clock again toggles it
        closed. The month grid is built in code. The transparent margin around Root leaves room
        for the drop shadow and for the slide travel.
    -->
    <Window.Resources>
        <!-- Borderless month/year paging arrows. -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TaskBtnFg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource TaskBtnHoverBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- "Today" text button. Kept laid out (Hidden, not Collapsed) when on the current
             month so showing/hiding it never resizes the flyout. -->
        <Style x:Key="TodayButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="12,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource TaskBtnHoverBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Root carries the themed surface, shadow, and the slide transform / fade we animate. -->
    <Border x:Name="Root" Margin="12" Opacity="0"
            Background="{DynamicResource StartMenuBg}"
            BorderBrush="{DynamicResource StartMenuBorder}" BorderThickness="1"
            CornerRadius="8" Padding="12">
        <Border.RenderTransform>
            <TranslateTransform x:Name="Slide"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.45" Color="#000000"/>
        </Border.Effect>
        <StackPanel Width="266">
            <!-- Header: « ‹ paging arrows, centred month/year, › » paging arrows. -->
            <Grid Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Style="{StaticResource NavButton}" Click="PrevYear_Click" ToolTip="Previous year">
                        <ui:SymbolIcon Symbol="ArrowPrevious24" FontSize="15"/>
                    </Button>
                    <Button Style="{StaticResource NavButton}" Click="PrevMonth_Click" ToolTip="Previous month">
                        <ui:SymbolIcon Symbol="ChevronLeft24" FontSize="16"/>
                    </Button>
                </StackPanel>
                <TextBlock x:Name="MonthLabel" HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource TaskBtnFg}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource NavButton}" Click="NextMonth_Click" ToolTip="Next month">
                        <ui:SymbolIcon Symbol="ChevronRight24" FontSize="16"/>
                    </Button>
                    <Button Style="{StaticResource NavButton}" Click="NextYear_Click" ToolTip="Next year">
                        <ui:SymbolIcon Symbol="ArrowNext24" FontSize="15"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Weekday header row and the 6×7 day grid (both filled in code). -->
            <UniformGrid x:Name="WeekdayHeader" Columns="7"/>
            <UniformGrid x:Name="DayGrid" Rows="6" Columns="7" Margin="0,2,0,0"/>

            <Button x:Name="TodayBtn" Style="{StaticResource TodayButton}" Content="Today"
                    HorizontalAlignment="Center" Margin="0,8,0,0"
                    Visibility="Hidden" Click="Today_Click"/>
        </StackPanel>
    </Border>
</Window>
