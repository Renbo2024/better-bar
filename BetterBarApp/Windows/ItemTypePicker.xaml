<Window x:Class="BetterBarApp.Windows.ItemTypePicker"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Item"
        Icon="pack://application:,,,/app.ico"
        Width="280"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Win11Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <DockPanel Margin="20,16,20,16">

        <TextBlock DockPanel.Dock="Top"
                   Text="Select item type"
                   FontFamily="Segoe UI Variable Display, Segoe UI"
                   FontSize="16" FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="OK"
                    Style="{StaticResource PrimaryButton}"
                    IsDefault="True" Margin="0,0,8,0"
                    Click="OK_Click"/>
            <Button Content="Cancel" IsCancel="True" Click="Cancel_Click"/>
        </StackPanel>

        <Border Background="{StaticResource SurfaceBg}"
                BorderBrush="{StaticResource CtrlBorder}"
                BorderThickness="1" CornerRadius="8">
            <ListBox x:Name="TypeList"
                     DisplayMemberPath="DisplayName"
                     BorderThickness="0" Background="Transparent"
                     MinHeight="60"
                     MouseDoubleClick="TypeList_MouseDoubleClick"/>
        </Border>

    </DockPanel>
</Window>
