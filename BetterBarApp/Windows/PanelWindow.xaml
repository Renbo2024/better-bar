<appbar:AppBarWindow x:Class="BetterBarApp.Windows.PanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:appbar="clr-namespace:ManagedShell.AppBar;assembly=ManagedShell.AppBar"
        xmlns:controls="clr-namespace:BetterBarApp.Controls"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource PanelBackground}"
        AllowDrop="True"
        Loaded="Window_Loaded">
    <appbar:AppBarWindow.Resources>
        <ResourceDictionary>
            <!-- Taskbar implicit styles (WPF-UI is the app default; the bar opts back in). -->
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Win11Styles.xaml"/>
                <ResourceDictionary Source="/Resources/SystemMenu.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <!--
                Defined here so we can open it explicitly in code.
                WindowStyle="None" windows don't receive WM_CONTEXTMENU reliably,
                so the automatic ContextMenuService never fires — manual IsOpen=true
                in MouseRightButtonUp is required.
            -->
            <ContextMenu x:Key="PanelMenu" Style="{StaticResource SystemContextMenu}">
                <MenuItem Header="BetterBar Settings" Click="Configure_Click" Style="{StaticResource SystemMenuItem}">
                    <MenuItem.Icon>
                        <Image Source="pack://application:,,,/app.ico" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator Style="{StaticResource SystemMenuSeparator}"/>
                <MenuItem Header="Exit BetterBar" Click="Exit_Click" Style="{StaticResource SystemMenuItem}">
                    <MenuItem.Icon>
                        <ui:SymbolIcon Symbol="Power24" Foreground="{DynamicResource TaskBtnFg}"/>
                    </MenuItem.Icon>
                </MenuItem>
            </ContextMenu>
        </ResourceDictionary>
    </appbar:AppBarWindow.Resources>

    <Grid x:Name="OuterGrid"
          Background="Transparent"
          ClipToBounds="True"
          AllowDrop="True"
          MouseRightButtonUp="Grid_MouseRightButtonUp">
        <!-- Items render left-to-right. BarItemsPanel sizes them: content-width for fixed
             items, proportional shrink for shrinkable items on overflow, then the grow-to-fill
             item consumes any remaining space. Grow/Shrinkable flags are set in code. -->
        <controls:BarItemsPanel x:Name="ItemsHost"
              AllowDrop="True"
              HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
    </Grid>
</appbar:AppBarWindow>
